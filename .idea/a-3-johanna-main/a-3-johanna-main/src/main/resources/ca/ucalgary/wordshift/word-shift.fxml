<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>

<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="ca.ucalgary.wordshift.WordShiftController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label prefHeight="30.0" prefWidth="180.0" text="Word Shift Game" alignment="CENTER"/>

    <GridPane fx:id="wordGrid" gridLinesVisible="false" prefHeight="384.0" prefWidth="150.0" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints minWidth="32.0" prefWidth="32.0"/>
            <ColumnConstraints minWidth="32.0" prefWidth="32.0"/>
            <ColumnConstraints minWidth="32.0" prefWidth="32.0"/>
            <ColumnConstraints minWidth="32.0" prefWidth="32.0"/>
            <ColumnConstraints minWidth="32.0" prefWidth="32.0"/>
            <ColumnConstraints minWidth="32.0" prefWidth="32.0"/>
            <ColumnConstraints minWidth="32.0" prefWidth="32.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
            <RowConstraints minHeight="32.0" prefHeight="32.0"/>
        </rowConstraints>
    </GridPane>

    <HBox prefHeight="30.0" prefWidth="180.0" spacing="15.0" alignment="CENTER" visible="true">
        <children>
            <TextField fx:id="guess_textfield" alignment="CENTER"/>
            <Button alignment="CENTER" onAction="#onGuess" text="Guess"/>
            <Label fx:id="guessStatus" text="Current Status"/>
        </children>
    </HBox>

    <Label prefHeight="30.0" prefWidth="180.0" text="Choose size of New Game" alignment="CENTER"/>

    <HBox alignment="CENTER" prefHeight="30.0" prefWidth="180.0" spacing="15.0">
        <children>
            <TextField fx:id="gameSize" alignment="CENTER" />
            <Button alignment="CENTER" onAction="#onPickSize" text="Enter Size [4-7]:" />
            <Label fx:id="sizeStatus" text="" />
        </children>
    </HBox>

</VBox>
